generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  displayName   String?
  status        String    @default("online")
  role          String    @default("user")
  globalMentionOptOut  Boolean @default(false)
  chatMentionOptOut    Boolean @default(false)
  commentMentionOptOut Boolean @default(false)
  searchLayout  String    @default("masonry-editorial")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  chatMessages  ChatMessage[]
  comments      Comment[]
  subjects      Subject[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ChatMessage {
  id        Int       @id @default(autoincrement())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  mentions  String[]
  deleted   Boolean   @default(false)
  editedAt  DateTime?
  createdAt DateTime  @default(now())
}

model Comment {
  id        Int       @id @default(autoincrement())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  themeId   Int
  theme     Theme     @relation(fields: [themeId], references: [id], onDelete: Cascade)
  parentId  Int?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  content   String
  mentions  String[]
  depth     Int       @default(0)
  deleted   Boolean   @default(false)
  editedAt  DateTime?
  createdAt DateTime  @default(now())

  @@index([themeId, parentId])
  @@index([themeId, createdAt])
}

model EditHistory {
  id         Int      @id @default(autoincrement())
  entityType String
  entityId   Int
  oldContent String
  editedAt   DateTime @default(now())

  @@index([entityType, entityId])
}

model Theme {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  slug     String    @unique
  icon     String    @default("Settings")
  subjects Subject[]
  articles NewsArticle[]
  comments Comment[]

  createdAt DateTime @default(now())
}

model Subject {
  id       Int    @id @default(autoincrement())
  type     String
  domaine  String
  sujet    String
  themeId  Int
  theme    Theme  @relation(fields: [themeId], references: [id])
  userId   String?
  user     User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  isPublic Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([themeId, isPublic])
}

model NewsArticle {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  description String
  content     String?
  url         String
  source      String
  image       String?
  favicon     String?
  publishedAt DateTime
  themeId     Int
  theme       Theme    @relation(fields: [themeId], references: [id])
  fetchedAt   DateTime @default(now())

  histories   NewsHistory[]
  summaries   AiSummary[]

  @@unique([url, themeId])
}

model NewsHistory {
  id        Int         @id @default(autoincrement())
  articleId Int
  article   NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  sessionId String
  visitedAt DateTime    @default(now())

  @@unique([articleId, sessionId])
  @@index([sessionId])
}

model AiSummary {
  id         Int          @id @default(autoincrement())
  articleId  Int?
  article    NewsArticle? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  subjectKey String?
  provider   String
  model      String
  content    String
  createdAt  DateTime     @default(now())

  @@unique([articleId, provider, model])
  @@unique([subjectKey, provider, model])
}
