# Copier en .env (local) ou poser à côté du docker-compose.yml (prod), puis
# remplacer toutes les valeurs entre <…>. Générer les secrets avec :
#   openssl rand -hex 32       # ou : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ---- Postgres -------------------------------------------------------------
# Utilisé par docker-compose pour provisionner la DB.
POSTGRES_USER=grandoral
POSTGRES_PASSWORD=<mot de passe fort>
POSTGRES_DB=grandoral

# ---- Database connection (Prisma) -----------------------------------------
# En local (Postgres natif) : localhost
# En Docker compose : le hostname est `postgres` (nom du service).
# Encoder le mot de passe si celui-ci contient des caractères réservés comme
# #, @, :, /, ?, &, %.
DATABASE_URL=postgresql://grandoral:<mot de passe fort>@localhost:5432/grandoral?schema=public

# ---- Better Auth ----------------------------------------------------------
# Secret de signature des sessions — ne jamais réutiliser entre environnements.
BETTER_AUTH_SECRET=<32 bytes hex>

# URLs publiques de l'app (mêmes valeurs).
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Discord OAuth --------------------------------------------------------
# Créer une application sur https://discord.com/developers/applications
# Redirect URL à ajouter : <BETTER_AUTH_URL>/api/auth/callback/discord
DISCORD_CLIENT_ID=<discord client id>
DISCORD_CLIENT_SECRET=<discord client secret>

# IDs Discord (séparés par virgules ou espaces) qui deviennent superadmin.
# Le statut superadmin n'est PAS stocké en DB, il est dérivé exclusivement
# de cette variable — modifiable uniquement par les ops du déploiement.
SUPER_ADMIN_DISCORD_IDS=<ton id discord>

# ---- Cron -----------------------------------------------------------------
# Requis pour /api/cron et pour appeler scripts/fetch-news.ts via cron host.
# La route refuse les requêtes si cette variable est absente (503).
CRON_SECRET=<32 bytes hex>

# ---- Optionnel ------------------------------------------------------------
# Si défini, scripts/fetch-news.ts utilise NewsAPI au lieu de Bing News RSS.
# NEWS_API_KEY=

# Port hôte exposé par docker-compose (défaut 3000). Utile si 3000 est pris.
# HOST_PORT=4070

# Ollama optionnel. En local hors Docker, laisser vide utilise localhost:11434.
# En Docker, laisser vide utilise le service Compose http://ollama:11434.
# OLLAMA_BASE_URL=
# OLLAMA_HOST_PORT=11434
# OLLAMA_KEEP_ALIVE=5m
# OLLAMA_MEM_LIMIT=6g
# OLLAMA_CPUS=2
